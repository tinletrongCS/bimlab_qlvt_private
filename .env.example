# bimlab_qlvt — cp .env.example .env rồi điền. KHÔNG commit .env.
DOCKER_REGISTRY=local
BIMLAB_TAG=latest

# DB: schema `asset` trong DB bimlab (sau DB-split 4-c → DB `qlvt`, schema GIỮ tên `asset`)
EXTERNAL_DB_HOST=postgres
POSTGRES_DB=bimlab
# DEV default — DB/MinIO/key dùng CHUNG với HRM (nối vào Postgres+MinIO của HRM). PHẢI giống hệt .env mọi repo. Override ở prod.
POSTGRES_USER=bimlab
POSTGRES_PASSWORD=dev-postgres-password

# s2s: key gọi auth-service/employee-service /internal. PHẢI giống hệt HRM ↔ CDS ↔ QLVT — lệch là 403.
INTERNAL_API_KEY=dev-local-internal-api-key

# Keycloak (realm bimlab — stack platform_bimlab)
AUTH_KEYCLOAK_ISSUER=http://localhost:8081/realms/bimlab
AUTH_KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/bimlab/protocol/openid-connect/certs
AUTH_KEYCLOAK_AUDIENCE_ASSET=asset-service

# MinIO (shared infra — host từ platform/monorepo stack). Giống hệt HRM/CDS.
MINIO_ROOT_USER=devminio
MINIO_ROOT_PASSWORD=dev-minio-password
