# bimlab_qlvt — cp .env.example .env rồi điền. KHÔNG commit .env.
DOCKER_REGISTRY=local
BIMLAB_TAG=latest

# DB: schema `asset` trong DB bimlab (sau DB-split 4-c → DB `qlvt`, schema GIỮ tên `asset`)
EXTERNAL_DB_HOST=postgres
POSTGRES_DB=bimlab
POSTGRES_USER=
POSTGRES_PASSWORD=

# s2s: key gọi auth-service /internal (đang sunset → Bearer-only, STEP-3 §3.0-c)
INTERNAL_API_KEY=

# Keycloak (realm bimlab — stack platform_bimlab)
AUTH_KEYCLOAK_ISSUER=
AUTH_KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/bimlab/protocol/openid-connect/certs
AUTH_KEYCLOAK_AUDIENCE_ASSET=asset-service

# MinIO (shared infra — host từ platform/monorepo stack)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
