# QLVT frontend — Phase 2 PR#5 (Keycloak SSO). Copy sang .env khi cần bật keycloak mode.

# Chế độ auth. Mặc định/bỏ trống = "legacy" (login HRM /auth/login + cookie + CSRF — KHÔNG đổi gì,
# = rollback). Đặt "keycloak" để bật Keycloak SSO (Authorization Code + PKCE, token in-memory + Bearer).
VITE_AUTH_MODE=legacy

# Chỉ dùng khi VITE_AUTH_MODE=keycloak:
VITE_KEYCLOAK_AUTHORITY=http://localhost:8081/realms/bimlab
VITE_KEYCLOAK_CLIENT_ID=qlvt
# redirect_uri PHẢI khớp redirectUris đã đăng ký ở realm client `qlvt`. Mặc định = window.origin + "/".
# Vite dev chạy port 5174 → realm đã whitelist http://localhost:5174/* (xem keycloak/realm-bimlab.json).
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5174/
